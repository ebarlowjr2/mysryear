# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Cron job secret for scheduled tasks
CRON_SECRET=your-cron-secret

# Scholarship ingestion (SERVER-SIDE ONLY — never expose to web/mobile clients)
# Required only for LIVE (non --dry-run) imports via `npm run scholarships:ingest`.
# The service-role key bypasses RLS; keep it out of source control and public env.
SUPABASE_URL=your-project-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Base URL used by API routes
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
