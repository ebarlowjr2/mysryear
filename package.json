{
  "name": "mysryear-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "typecheck": "npm --workspace packages/shared run typecheck && npm --workspace apps/web run typecheck",
    "test": "npm --workspace packages/shared run test && npm --workspace apps/web run test",
    "test:e2e": "npm --workspace apps/web run test:e2e",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "mobile:start": "npm --workspace apps/mobile run start",
    "mobile:ios": "npm --workspace apps/mobile run ios",
    "mobile:android": "npm --workspace apps/mobile run android",
    "mobile:verify": "npm --workspace apps/mobile run start -- --help",
    "scholarships:ingest": "tsx scripts/scholarships/import-scholarships.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "tsx": "^4.19.2"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
